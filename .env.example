DISCORD_BOT_TOKEN=
DISCORD_COMMAND_PREFIX=!
SCROLLKEEPER_DATA_DIR=./data
SCROLLKEEPER_BOT_NAME=ScrollKeeper
SCROLLKEEPER_DOCKER_NETWORK=scrollkeeper-net
SCROLLKEEPER_WHISPER_IMAGE=scrollkeeper-whisper:latest
SCROLLKEEPER_WHISPER_CONTAINER=scrollkeeper-whisper
SCROLLKEEPER_WHISPER_PORT=9000
SCROLLKEEPER_WHISPER_MODEL=small.en
SCROLLKEEPER_WHISPER_COMPUTE_TYPE=float16
SCROLLKEEPER_WHISPER_VAD_FILTER=true
SCROLLKEEPER_SUMMARY_SINGLE_PASS_MAX_CHARS=90000
SCROLLKEEPER_SUMMARY_CHUNK_CHARS=45000
SCROLLKEEPER_SUMMARY_PROMPT_APPEND=
SCROLLKEEPER_OLLAMA_IMAGE=ollama/ollama:latest
SCROLLKEEPER_OLLAMA_CONTAINER=scrollkeeper-ollama
SCROLLKEEPER_OLLAMA_PORT=11434
SCROLLKEEPER_OLLAMA_MODEL=qwen3.5:9b
SCROLLKEEPER_OLLAMA_EMBED_MODEL=qwen3-embedding:4b
SCROLLKEEPER_OLLAMA_IDLE_TIMEOUT=0
SCROLLKEEPER_GPU_POLICY=concurrent
SCROLLKEEPER_ENABLE_GPU=true
